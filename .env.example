# WorldCup Oracle runs without keys in SAMPLE_DATASET_MODE.
# Add provider keys only on the server side. Never expose them as NEXT_PUBLIC_*.

# none -> SAMPLE_DATASET_MODE
# football-data/api-football without a key -> OFFLINE_DATASET_MODE
# football-data/api-football with the matching key -> LIVE_PROVIDER_MODE
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_INTRO=true
LIVE_DATA_PROVIDER=none

# Near-live World Cup scores (/api/live + the LiveScoreStrip ticker).
# Uses football-data.org's FREE tier only. Get a key at
# https://www.football-data.org/client/register and set:
#   LIVE_DATA_PROVIDER=football-data
#   FOOTBALL_DATA_API_KEY=<your key>
# Results are cached server-side for 45s, so the provider is called at most once
# per window regardless of how many clients poll (well within the free-tier
# rate limit). With no key, the strip shows a labeled "scores unavailable"
# state and the app stays in the offline dataset mode.
FOOTBALL_DATA_API_KEY=
API_FOOTBALL_KEY=

# Future persistence target:
DATABASE_URL=
